<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 이미지 저장을 위한 권한 (API 28 이하에서 필요) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 이미지 읽기 권한 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13+ 미디어 권한 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- 카카오톡 공유를 위한 쿼리 권한 (API 30+) -->
    <queries>
        <package android:name="com.kakao.talk" />
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/*" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_playstore"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_playstore"
        android:supportsRtl="true"
        android:theme="@style/Theme.Capston"
        android:name="example.capston.App"
        tools:targetApi="31"
        android:usesCleartextTraffic="true">

        <!-- FileProvider 설정 (공유 시 필요할 수 있음) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Firebase Cloud Messaging -->
        <service
            android:name="com.capston.presentation.service.LandrFireBaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>

            <!-- 토큰 자동 초기화 방지 -->
            <meta-data
                android:name="firebase_messaging_auto_init_enabled"
                android:value="false" />
            <meta-data
                android:name="firebase_analytics_collection_enabled"
                android:value="false" />
        </service>

        <!-- 스플래시 액티비티를 시작 액티비티로 설정 -->
        <activity
            android:name="com.capston.presentation.ui.SplashActivity"
            android:windowSoftInputMode="adjustPan"
            android:launchMode="singleTop"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.capston.presentation.ui.login.LoginActivity"
            android:windowSoftInputMode="adjustPan"
            android:launchMode="singleTop"
            android:exported="true">
        </activity>

        <!-- MainActivity는 로그인 이후로 전환 -->
        <activity
            android:name="com.capston.presentation.ui.MainActivity"
            android:windowSoftInputMode="adjustPan"
            android:launchMode="singleTop"
            android:exported="true" >
<!--            <intent-filter>-->
<!--                <action android:name="android.intent.action.MAIN" />-->
<!--                <category android:name="android.intent.category.LAUNCHER" />-->
<!--            </intent-filter>-->
        </activity>

        <activity
            android:name="com.capston.presentation.ui.onboarding.OnboardingActivity"
            android:windowSoftInputMode="adjustPan"
            android:launchMode="singleTop"
            android:exported="true">
        </activity>
    </application>

</manifest>